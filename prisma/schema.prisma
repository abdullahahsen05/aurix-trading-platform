generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TRADER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum AccountStatus {
  PENDING
  CONNECTED
  SYNCING
  DISCONNECTED
  RESTRICTED
}

enum TradeStatus {
  OPEN
  CLOSED
}

enum TradeSide {
  BUY
  SELL
}

enum RiskSeverity {
  INFO
  WARNING
  CRITICAL
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String?
  name            String
  role            UserRole
  status          UserStatus      @default(PENDING)
  traderProfile   TraderProfile?
  tradingAccounts TradingAccount[]
  auditLogs       AuditLog[]      @relation("ActorAuditLogs")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model TraderProfile {
  id            String         @id @default(cuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id])
  segment       String         @default("EVALUATION")
  notes         CrmNote[]
  activities    CrmActivity[]
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model TradingAccount {
  id              String              @id @default(cuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id])
  accountName     String
  brokerName      String
  brokerAccountId String?
  status          AccountStatus       @default(PENDING)
  currency        String              @default("USD")
  credentials     BrokerCredential?
  snapshots       AccountSnapshot[]
  trades          Trade[]
  dailyMetrics    DailyAccountMetric[]
  riskRules       RiskRule[]
  riskEvents      RiskEvent[]
  notifications   Notification[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([userId, status], map: "idx_trading_accounts_user_status")
}

model BrokerCredential {
  id                 String         @id @default(cuid())
  tradingAccountId   String         @unique
  tradingAccount     TradingAccount @relation(fields: [tradingAccountId], references: [id])
  provider           String
  encryptedReference String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model AccountSnapshot {
  id               String         @id @default(cuid())
  tradingAccountId String
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id])
  balance          Decimal        @db.Decimal(18, 2)
  equity           Decimal        @db.Decimal(18, 2)
  floatingPnl      Decimal        @db.Decimal(18, 2)
  drawdownPercent  Decimal        @db.Decimal(7, 2)
  capturedAt       DateTime

  @@index([tradingAccountId, capturedAt(sort: Desc)], map: "idx_account_snapshots_account_time")
}

model Trade {
  id               String         @id @default(cuid())
  tradingAccountId String
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id])
  symbol           String
  side             TradeSide
  status           TradeStatus
  volume           Decimal        @db.Decimal(12, 4)
  openPrice        Decimal        @db.Decimal(18, 6)
  closePrice       Decimal?       @db.Decimal(18, 6)
  profit           Decimal        @db.Decimal(18, 2)
  currency         String         @default("USD")
  openedAt         DateTime
  closedAt         DateTime?

  @@index([tradingAccountId, status, openedAt(sort: Desc)], map: "idx_trades_account_status_opened")
}

model DailyAccountMetric {
  id                 String         @id @default(cuid())
  tradingAccountId   String
  tradingAccount     TradingAccount @relation(fields: [tradingAccountId], references: [id])
  metricDay          DateTime       @db.Date
  profit             Decimal        @db.Decimal(18, 2)
  winRatePercent     Decimal        @db.Decimal(7, 2)
  maxDrawdownPercent Decimal        @db.Decimal(7, 2)
  tradeCount         Int
  createdAt          DateTime       @default(now())

  @@unique([tradingAccountId, metricDay])
  @@index([tradingAccountId, metricDay(sort: Desc)], map: "idx_daily_metrics_account_day")
}

model RiskRule {
  id               String          @id @default(cuid())
  tradingAccountId String?
  tradingAccount   TradingAccount? @relation(fields: [tradingAccountId], references: [id])
  name             String
  severity         RiskSeverity
  metric           String
  threshold        Decimal         @db.Decimal(18, 2)
  enabled          Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model RiskEvent {
  id               String         @id @default(cuid())
  tradingAccountId String
  tradingAccount   TradingAccount @relation(fields: [tradingAccountId], references: [id])
  ruleName         String
  severity         RiskSeverity
  message          String
  acknowledgedAt   DateTime?
  createdAt        DateTime       @default(now())

  @@index([tradingAccountId, createdAt(sort: Desc)], map: "idx_risk_events_account_created")
}

model CrmNote {
  id              String        @id @default(cuid())
  traderProfileId String
  traderProfile   TraderProfile @relation(fields: [traderProfileId], references: [id])
  authorName      String
  note            String
  createdAt       DateTime      @default(now())

  @@index([traderProfileId, createdAt(sort: Desc)], map: "idx_crm_notes_trader_created")
}

model CrmActivity {
  id              String        @id @default(cuid())
  traderProfileId String
  traderProfile   TraderProfile @relation(fields: [traderProfileId], references: [id])
  type            String
  description     String
  createdAt       DateTime      @default(now())
}

model Subscription {
  id              String        @id @default(cuid())
  traderProfileId String
  traderProfile   TraderProfile @relation(fields: [traderProfileId], references: [id])
  planName        String
  status          String
  startedAt       DateTime
  endsAt          DateTime?
}

model Notification {
  id               String          @id @default(cuid())
  tradingAccountId String?
  tradingAccount   TradingAccount? @relation(fields: [tradingAccountId], references: [id])
  userId           String?
  title            String
  message          String
  readAt           DateTime?
  createdAt        DateTime        @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation("ActorAuditLogs", fields: [actorUserId], references: [id])
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId, createdAt(sort: Desc)], map: "idx_audit_logs_actor_created")
}
