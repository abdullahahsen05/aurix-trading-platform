# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Database password (for migration runner only)
SUPABASE_DB_PASSWORD=your-db-password

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Broker integration (MetaAPI / MT5)
METAAPI_TOKEN=
# Provisioning reliability tier: "regular" (default) or "high".
METAAPI_RELIABILITY=regular
BROKER_PROVIDER=metaapi
# Live copy-trading order execution master switch. Leave false until you have
# verified execution on a DEMO MT5 account. When false, live copy returns
# COPY_EXECUTION_NOT_CONFIGURED (no orders are ever placed).
BROKER_EXECUTION_ENABLED=false

# Background worker / job queue (Phase 4.6)
# Shared secret required (in production) to call /api/worker/jobs/* — set this to
# a long random string and pass it as the `x-worker-secret` header (e.g. from Vercel Cron).
WORKER_SECRET=
# Max jobs processed per worker run (hard-capped at 20).
WORKER_MAX_JOBS_PER_RUN=5
# Minutes before a stuck RUNNING job is released by CLEANUP_STALE_JOBS.
WORKER_STALE_JOB_MINUTES=15

# Encryption key for broker credentials (AES-256-GCM via SHA-256 derivation).
# Required to store MT5 credentials. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Market Data Terminal (Phase 8)
# Default provider is "mock" — demo data, no credentials needed.
# To enable institutional dxFeed data: set MARKET_DATA_PROVIDER=dxfeed and all DXFEED_* vars.
# Obtain credentials and API documentation from dxFeed / Devexperts before enabling.
MARKET_DATA_PROVIDER=mock
DXFEED_ENABLED=false
DXFEED_API_BASE_URL=
DXFEED_API_KEY=
DXFEED_ACCOUNT_ID=
DXFEED_ENVIRONMENT=demo
# Set to "true" while using mock provider so the UI clearly labels data as demo.
NEXT_PUBLIC_TERMINAL_DEMO_MODE=true

# dxFeed Candelabra White-Label Widget Suite (Phase 8.5)
# Obtain all values by contacting dxFeed / Devexperts: https://dxfeed.com
# Reference: https://widgets.dxfeed.com/docs/widgets/
#
# CDN bundle URL — provisioned by dxFeed; exposes the four widget factory
# functions as browser globals. Safe to make NEXT_PUBLIC (it is a URL, not a credential).
# When set, /terminal automatically renders the Candelabra widget terminal.
NEXT_PUBLIC_DXFEED_WIDGET_CDN_URL=
#
# Data provider endpoints — all SERVER-SIDE only (no NEXT_PUBLIC_ prefix).
# Auth headers are injected by the /api/dxfeed/* proxy routes; they never reach the browser.
DXFEED_WIDGET_CDN_URL=
DXFEED_IPF_PATH=
DXFEED_IPF_AUTH_HEADER=
DXFEED_FEED_PATH=
DXFEED_FEED_AUTH_HEADER=
DXFEED_SCANNER_PATH=
DXFEED_SCANNER_AUTH_HEADER=
DXFEED_NEWS_PATH=
DXFEED_NEWS_AUTH_HEADER=
DXFEED_SCHEDULE_PATH=
# Optional: token exchange endpoint for WebSocket short-lived auth.
# If set, /api/dxfeed/feed-token exchanges the server key for a short-lived
# connection token that is appended to the WebSocket URL as ?token=<t>.
# The main DXFEED_FEED_AUTH_HEADER never reaches the browser.
DXFEED_TOKEN_EXCHANGE_URL=

# AI Trading Assistant (Phase 1)
# Server-only — never exposed to the browser.
GEMINI_API_KEY=
AI_CHAT_DAILY_LIMIT=20
AI_CHART_DAILY_LIMIT=3
# Model IDs are environment-driven. Leave blank to use the built-in
# currently-supported defaults (chat: gemini-2.5-flash, chart: gemini-2.5-pro),
# or set explicit values below. Verify supported IDs in Google AI Studio.
AI_DEFAULT_MODEL=
AI_CHART_MODEL=
